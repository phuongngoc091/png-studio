{
  "schemaVersion": "lastudio.example.v1",
  "id": "tts-basic-en",
  "title": "Basic English TTS smoke test",
  "task": "tts",
  "model": {
    "familyId": null,
    "required": false
  },
  "capabilities": ["tts", "en"],
  "inputs": {
    "text": "Hello, this is a short English text-to-speech test in LA Studio."
  },
  "settings": {
    "lang": "en",
    "temperature": 0.45,
    "top_k": 15,
    "top_p": 0.85
  },
  "expected": {
    "output": "A short English speech waveform.",
    "manualChecks": [
      "Audio is generated without runtime errors.",
      "English words are understandable.",
      "The generated audio is not clipped or prematurely cut off."
    ]
  }
}

