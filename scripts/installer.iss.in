; Inno Setup template for PNG Studio. CMake generates installer.iss per build.
; See https://jrsoftware.org/isinfo.php for details

[Setup]
AppName=PNG Studio
AppVersion=@PROJECT_VERSION@
AppPublisher=Tran Dai Duong
AppPublisherURL=https://github.com/dduongtrandai/PNG-Studio
AppSupportURL=https://github.com/dduongtrandai/PNG-Studio/issues
AppUpdatesURL=https://github.com/dduongtrandai/PNG-Studio/releases
DefaultDirName={autopf}\PNG Studio
DefaultGroupName=PNG Studio
DisableProgramGroupPage=yes
; LicenseFile=../LICENSE
OutputDir=@PNGSTUDIO_INSTALLER_OUTPUT_DIR@
OutputBaseFilename=PNG-Studio-Setup
Compression=lzma2
SolidCompression=yes
WizardStyle=modern
UninstallDisplayIcon={app}\bin\PNG Studio.exe
SetupIconFile=@PNGSTUDIO_INSTALLER_ICON_FILE@
ArchitecturesAllowed=x64
ArchitecturesInstallIn64BitMode=x64

[Languages]
Name: "english"; MessagesFile: "compiler:Default.isl"

[Tasks]
Name: "desktopicon"; Description: "{cm:CreateDesktopIcon}"; GroupDescription: "{cm:AdditionalIcons}"; Flags: unchecked

[Files]
Source: "@PNGSTUDIO_INSTALLER_STAGE_DIR@\*"; DestDir: "{app}"; Flags: recursesubdirs createallsubdirs

[Icons]
Name: "{group}\PNG Studio"; Filename: "{app}\bin\PNG Studio.exe"
Name: "{autodesktop}\PNG Studio"; Filename: "{app}\bin\PNG Studio.exe"; Tasks: desktopicon

[Run]
Filename: "{app}\bin\PNG Studio.exe"; Description: "{cm:LaunchProgram,PNG Studio}"; Flags: nowait postinstall skipifsilent
Filename: "{app}\bin\PNG Studio.exe"; Flags: nowait skipifnotsilent
